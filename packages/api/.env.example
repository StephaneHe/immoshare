# ─── Database ───
DATABASE_URL="postgresql://immo:immo@localhost:5432/immoshare"

# ─── Auth ───
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ───
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
PUBLIC_URL="https://app.immoshare.com"

# ─── MinIO / S3 Storage ───
# For local dev, MinIO runs via docker-compose (http://localhost:9000)
# Web console available at http://localhost:9001 (user: immoshare / pass: immoshare123)
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_PUBLIC_URL="http://localhost:9000"
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="immoshare-media"
STORAGE_ACCESS_KEY="immoshare"
STORAGE_SECRET_KEY="immoshare123"

# ─── Email (Brevo) ───
# Free tier: 300 emails/day — https://www.brevo.com
# Without this key, emails are logged to console (stub mode)
# BREVO_API_KEY="your-brevo-api-key"
# BREVO_FROM_EMAIL="noreply@yourdomain.com"
# BREVO_FROM_NAME="ImmoShare"

# ─── WhatsApp (future) ───
# WHATSAPP_TOKEN="your-meta-access-token"
# WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"

# ─── SMS / Twilio (future) ───
# TWILIO_ACCOUNT_SID="your-account-sid"
# TWILIO_AUTH_TOKEN="your-auth-token"
# TWILIO_FROM_NUMBER="+1234567890"
