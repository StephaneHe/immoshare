// Prisma schema — ImmoShare
// Modules: M1 Auth, M2 Agencies, M3 Properties, M4 Pages, M5 Sharing, M6 Tracking, M7 Partners
// Tables: User, RefreshToken, EmailVerification, PasswordReset, Agency, AgencyInvite, Property, Media, Page, Contact, ShareLink, ShareBatch, TrackEvent, PartnerInvite, ReshareRequest

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// M1 — Auth
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  phone         String?
  avatarUrl     String?   @map("avatar_url")
  role          UserRole  @default(AGENT)
  agencyId      String?   @map("agency_id")
  locale        String    @default("he")
  emailVerified Boolean   @default(false) @map("email_verified")
  isActive      Boolean   @default(true)  @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt      @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  ownedAgency        Agency?         @relation("AgencyAdmin")
  agency             Agency?         @relation("AgencyMembers", fields: [agencyId], references: [id])
  sentInvites        AgencyInvite[]  @relation("InviteSender")
  properties         Property[]
  contacts           Contact[]
  shareBatches       ShareBatch[]
  partnerInvitesSent  PartnerInvite[] @relation("PartnerInviter")
  partnerInvitesRecv  PartnerInvite[] @relation("PartnerInvitee")
  resharePartner      ReshareRequest[] @relation("ResharePartner")
  reshareResolver     ReshareRequest[] @relation("ReshareResolver")
  notifications        Notification[]
  notificationSettings NotificationSettings?
  pushTokens           PushToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model EmailVerification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([token])
  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([token])
  @@map("password_resets")
}

enum UserRole {
  SUPER_ADMIN  @map("super_admin")
  AGENCY_ADMIN @map("agency_admin")
  AGENT        @map("agent")
  PARTNER      @map("partner")
  @@map("user_role")
}

// ============================================================
// M2 — Agencies
// ============================================================

model Agency {
  id        String    @id @default(uuid())
  name      String
  address   String?
  city      String?
  phone     String?
  email     String?
  logoUrl   String?   @map("logo_url")
  website   String?
  adminId   String    @unique @map("admin_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  admin      User           @relation("AgencyAdmin", fields: [adminId], references: [id])
  members    User[]         @relation("AgencyMembers")
  invites    AgencyInvite[]
  properties Property[]
  @@map("agencies")
}

model AgencyInvite {
  id         String             @id @default(uuid())
  agencyId   String             @map("agency_id")
  email      String
  invitedBy  String             @map("invited_by")
  status     AgencyInviteStatus @default(PENDING)
  token      String             @unique
  expiresAt  DateTime           @map("expires_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  resolvedAt DateTime?          @map("resolved_at")
  agency  Agency @relation(fields: [agencyId], references: [id])
  inviter User   @relation("InviteSender", fields: [invitedBy], references: [id])
  @@index([token])
  @@index([email])
  @@map("agency_invites")
}

enum AgencyInviteStatus {
  PENDING  @map("pending")
  ACCEPTED @map("accepted")
  DECLINED @map("declined")
  EXPIRED  @map("expired")
  REVOKED  @map("revoked")
  @@map("agency_invite_status")
}

// ============================================================
// M3 — Properties
// ============================================================

model Property {
  id           String         @id @default(uuid())
  ownerId      String         @map("owner_id")
  agencyId     String?        @map("agency_id")
  title        String
  description  String?        @db.Text
  propertyType PropertyType   @map("property_type")
  status       PropertyStatus @default(DRAFT)
  price        Decimal?       @db.Decimal(12, 2)
  currency     String         @default("ILS")
  address      String?
  city         String?
  neighborhood String?
  areaSqm      Decimal?       @map("area_sqm") @db.Decimal(8, 2)
  rooms        Decimal?       @db.Decimal(3, 1)
  bedrooms     Int?
  bathrooms    Int?
  floor        Int?
  totalFloors  Int?           @map("total_floors")
  yearBuilt    Int?           @map("year_built")
  parking      Int?           @default(0)
  elevator     Boolean?
  balcony      Boolean?
  garden       Boolean?
  aircon       Boolean?       @map("air_conditioning")
  furnished    Boolean?
  metadata     Json?          @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")
  owner  User    @relation(fields: [ownerId], references: [id])
  agency Agency? @relation(fields: [agencyId], references: [id])
  media  Media[]
  pages  Page[]
  reshareRequests ReshareRequest[]
  @@index([ownerId])
  @@index([agencyId])
  @@index([status])
  @@index([city])
  @@map("properties")
}

model Media {
  id           String    @id @default(uuid())
  propertyId   String    @map("property_id")
  type         MediaType
  url          String
  thumbnailUrl String?   @map("thumbnail_url")
  mimeType     String    @map("mime_type")
  sizeBytes    Int       @map("size_bytes")
  width        Int?
  height       Int?
  order        Int       @default(0)
  caption      String?
  createdAt    DateTime  @default(now()) @map("created_at")
  property Property @relation(fields: [propertyId], references: [id])
  @@index([propertyId])
  @@map("media")
}

enum PropertyType {
  APARTMENT        @map("apartment")
  HOUSE            @map("house")
  PENTHOUSE        @map("penthouse")
  DUPLEX           @map("duplex")
  GARDEN_APARTMENT @map("garden_apartment")
  STUDIO           @map("studio")
  VILLA            @map("villa")
  COTTAGE          @map("cottage")
  LAND             @map("land")
  COMMERCIAL       @map("commercial")
  OFFICE           @map("office")
  OTHER            @map("other")
  @@map("property_type")
}

enum PropertyStatus {
  DRAFT       @map("draft")
  ACTIVE      @map("active")
  UNDER_OFFER @map("under_offer")
  SOLD        @map("sold")
  RENTED      @map("rented")
  ARCHIVED    @map("archived")
  @@map("property_status")
}

enum MediaType {
  PHOTO      @map("photo")
  FLOOR_PLAN @map("floor_plan")
  MODEL_3D   @map("model_3d")
  VIDEO      @map("video")
  DOCUMENT   @map("document")
  @@map("media_type")
}

// ============================================================
// M4 — Pages
// ============================================================

model Page {
  id               String      @id @default(uuid())
  propertyId       String      @map("property_id")
  brandingId       String?     @map("branding_id")
  title            String?
  selectedElements Json        @map("selected_elements")
  layout           String      @default("standard")
  isActive         Boolean     @default(true) @map("is_active")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  property   Property    @relation(fields: [propertyId], references: [id])
  shareLinks ShareLink[]
  @@index([propertyId])
  @@map("pages")
}

// ============================================================
// M5 — Sharing & Contacts
// ============================================================

model Contact {
  id        String   @id @default(uuid())
  ownerId   String   @map("owner_id")
  name      String
  phone     String?
  email     String?
  tags      String[] @default([])
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  owner      User        @relation(fields: [ownerId], references: [id])
  shareLinks ShareLink[]
  @@index([ownerId])
  @@map("contacts")
}

model ShareLink {
  id          String       @id @default(uuid())
  pageId      String       @map("page_id")
  contactId   String       @map("contact_id")
  channel     ShareChannel
  token       String       @unique
  isActive    Boolean      @default(true) @map("is_active")
  expiresAt   DateTime     @map("expires_at")
  sentAt      DateTime?    @map("sent_at")
  deliveredAt DateTime?    @map("delivered_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  page        Page         @relation(fields: [pageId], references: [id])
  contact     Contact      @relation(fields: [contactId], references: [id])
  trackEvents TrackEvent[]
  @@index([token])
  @@index([pageId])
  @@index([contactId])
  @@map("share_links")
}

model ShareBatch {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  pageId      String   @map("page_id")
  linkIds     String[] @map("link_ids")
  totalSent   Int      @map("total_sent")
  totalFailed Int      @default(0) @map("total_failed")
  createdAt   DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id])
  @@map("share_batches")
}

enum ShareChannel {
  WHATSAPP @map("whatsapp")
  EMAIL    @map("email")
  SMS      @map("sms")
  @@map("share_channel")
}

// ============================================================
// M6 — Tracking & Analytics
// ============================================================

model TrackEvent {
  id        String         @id @default(uuid())
  linkId    String         @map("link_id")
  eventType TrackEventType @map("event_type")
  timestamp DateTime       @default(now())
  ipAddress String?        @map("ip_address")
  userAgent String?        @map("user_agent")
  metadata  Json?          @default("{}")
  createdAt DateTime       @default(now()) @map("created_at")
  link ShareLink @relation(fields: [linkId], references: [id])
  @@index([linkId])
  @@index([eventType])
  @@index([timestamp])
  @@map("track_events")
}

enum TrackEventType {
  PAGE_OPENED    @map("page_opened")
  SECTION_VIEWED @map("section_viewed")
  MEDIA_VIEWED   @map("media_viewed")
  TIME_SPENT     @map("time_spent")
  PAGE_CLOSED    @map("page_closed")
  @@map("track_event_type")
}

// ============================================================
// M7 — Partners & Reshare
// ============================================================

model PartnerInvite {
  id          String              @id @default(uuid())
  inviterId   String              @map("inviter_id")
  inviteeId   String?             @map("invitee_id")
  code        String              @unique
  status      PartnerInviteStatus @default(PENDING)
  permissions Json                @default("{\"canView\": true, \"canReshare\": false}")
  expiresAt   DateTime            @map("expires_at")
  acceptedAt  DateTime?           @map("accepted_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  inviter User  @relation("PartnerInviter", fields: [inviterId], references: [id])
  invitee User? @relation("PartnerInvitee", fields: [inviteeId], references: [id])
  @@index([code])
  @@index([inviterId])
  @@index([inviteeId])
  @@map("partner_invites")
}

model ReshareRequest {
  id          String               @id @default(uuid())
  partnerId   String               @map("partner_id")
  propertyId  String               @map("property_id")
  status      ReshareRequestStatus @default(PENDING)
  message     String?              @db.Text
  requestedAt DateTime             @default(now()) @map("requested_at")
  resolvedAt  DateTime?            @map("resolved_at")
  resolvedBy  String?              @map("resolved_by")
  partner  User     @relation("ResharePartner", fields: [partnerId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  resolver User?    @relation("ReshareResolver", fields: [resolvedBy], references: [id])
  @@unique([partnerId, propertyId])
  @@index([propertyId])
  @@index([status])
  @@map("reshare_requests")
}

enum PartnerInviteStatus {
  PENDING  @map("pending")
  ACCEPTED @map("accepted")
  REVOKED  @map("revoked")
  EXPIRED  @map("expired")
  @@map("partner_invite_status")
}

enum ReshareRequestStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")
  @@map("reshare_request_status")
}

// ============================================================
// M8 — Notifications
// ============================================================

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?            @default("{}")
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationSettings {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  pushEnabled         Boolean  @default(true) @map("push_enabled")
  emailEnabled        Boolean  @default(true) @map("email_enabled")
  reminderNoOpenDays  Int      @default(3) @map("reminder_no_open_days")
  linkExpiryAlertDays Int      @default(7) @map("link_expiry_alert_days")
  quietHoursStart     String?  @map("quiet_hours_start")
  quietHoursEnd       String?  @map("quiet_hours_end")
  disabledTypes       String[] @default([]) @map("disabled_types")
  user User @relation(fields: [userId], references: [id])
  @@map("notification_settings")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String
  createdAt DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id])
  @@index([userId])
  @@map("push_tokens")
}

enum NotificationType {
  LINK_OPENED       @map("link_opened")
  RESHARE_REQUESTED @map("reshare_requested")
  RESHARE_APPROVED  @map("reshare_approved")
  RESHARE_REJECTED  @map("reshare_rejected")
  PARTNER_JOINED    @map("partner_joined")
  LINK_EXPIRING     @map("link_expiring")
  REMINDER_NO_OPEN  @map("reminder_no_open")
  PROPERTY_VIEWED   @map("property_viewed")
  SEND_FAILED       @map("send_failed")
  @@map("notification_type")
}
