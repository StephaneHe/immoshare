// Prisma schema — ImmoShare
// Modules: M1 Auth, M2 Agencies
// Tables: User, RefreshToken, EmailVerification, PasswordReset, Agency, AgencyInvite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// M1 — Auth
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  phone         String?
  avatarUrl     String?   @map("avatar_url")
  role          UserRole  @default(AGENT)
  agencyId      String?   @map("agency_id")
  locale        String    @default("he")
  emailVerified Boolean   @default(false) @map("email_verified")
  isActive      Boolean   @default(true)  @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt      @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]

  // M2 — Agency relations
  ownedAgency        Agency?         @relation("AgencyAdmin")
  agency             Agency?         @relation("AgencyMembers", fields: [agencyId], references: [id])
  sentInvites        AgencyInvite[]  @relation("InviteSender")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model EmailVerification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_resets")
}

enum UserRole {
  SUPER_ADMIN  @map("super_admin")
  AGENCY_ADMIN @map("agency_admin")
  AGENT        @map("agent")
  PARTNER      @map("partner")

  @@map("user_role")
}

// ============================================================
// M2 — Agencies
// ============================================================

model Agency {
  id        String    @id @default(uuid())
  name      String
  address   String?
  city      String?
  phone     String?
  email     String?
  logoUrl   String?   @map("logo_url")
  website   String?
  adminId   String    @unique @map("admin_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  admin   User           @relation("AgencyAdmin", fields: [adminId], references: [id])
  members User[]         @relation("AgencyMembers")
  invites AgencyInvite[]

  @@map("agencies")
}

model AgencyInvite {
  id         String             @id @default(uuid())
  agencyId   String             @map("agency_id")
  email      String
  invitedBy  String             @map("invited_by")
  status     AgencyInviteStatus @default(PENDING)
  token      String             @unique
  expiresAt  DateTime           @map("expires_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  resolvedAt DateTime?          @map("resolved_at")

  agency  Agency @relation(fields: [agencyId], references: [id])
  inviter User   @relation("InviteSender", fields: [invitedBy], references: [id])

  @@index([token])
  @@index([email])
  @@map("agency_invites")
}

enum AgencyInviteStatus {
  PENDING  @map("pending")
  ACCEPTED @map("accepted")
  DECLINED @map("declined")
  EXPIRED  @map("expired")
  REVOKED  @map("revoked")

  @@map("agency_invite_status")
}
